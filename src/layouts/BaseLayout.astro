---
import '@styles/global.css';
import { getConfig } from '@utils/config';
import { generateLocalBusinessSchema } from '@utils/seo';
import Analytics from '@components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonicalUrl?: string;
  schema?: object | object[];
}

const config = getConfig();
const {
  title = config.seo.defaultTitle,
  description = config.seo.defaultDescription,
  image = config.seo.defaultImage,
  noindex = false,
  canonicalUrl,
  schema,
} = Astro.props;

const siteUrl = import.meta.env.SITE_URL || 'https://amgfisio.es';
const currentUrl = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).href;

const localBusinessSchema = generateLocalBusinessSchema();
const allSchemas = schema
  ? Array.isArray(schema)
    ? [localBusinessSchema, ...schema]
    : [localBusinessSchema, schema]
  : [localBusinessSchema];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={currentUrl} />

  <!-- Geo Meta Tags (Local SEO) -->
  <meta name="geo.region" content="ES-CL" />
  <meta name="geo.placename" content="Valladolid" />
  <meta name="geo.position" content="41.6528;-4.7286" />
  <meta name="ICBM" content="41.6528, -4.7286" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content={config.business.name} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={currentUrl} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/images/isotipo-main.svg" />
  <link rel="apple-touch-icon" href="/images/isotipo-main.svg" />

  <!-- PWA -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#a6c958" />

  <!-- Preconnect -->
  <link rel="preconnect" href="https://maps.googleapis.com" />

  <!-- Fonts Preload -->
  <link rel="preload" href="/fonts/Sora-VariableFont_wght.ttf" as="font" type="font/ttf" crossorigin />
  <link rel="preload" href="/fonts/Reiswar.ttf" as="font" type="font/ttf" crossorigin />

  <!-- Structured Data -->
  {allSchemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- Analytics -->
  <Analytics />

  <!-- Slot for extra head content -->
  <slot name="head" />
</head>
<body>
  <slot name="header" />
  <main>
    <slot />
  </main>
  <slot name="footer" />

  <!-- WhatsApp Floating Button -->
  <a
    href={`https://wa.me/${config.contact.whatsapp}?text=${encodeURIComponent('Hola, me gustaria pedir cita en AMG Fisioterapia.')}`}
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-fab"
    aria-label="Contactar por WhatsApp"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Service Worker Registration -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>

  <style>
    .whatsapp-fab {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: var(--z-sticky);
      display: flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      background-color: #25D366;
      color: white;
      border-radius: var(--radius-full);
      box-shadow: var(--shadow-lg);
      transition: transform var(--duration-normal) var(--ease-out),
                  box-shadow var(--duration-normal) var(--ease-out);
    }

    .whatsapp-fab:hover {
      transform: scale(1.08);
      box-shadow: var(--shadow-xl);
    }

    @media (max-width: 768px) {
      .whatsapp-fab {
        bottom: 16px;
        right: 16px;
        width: 50px;
        height: 50px;
      }
    }
  </style>
</body>
</html>
