---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getConfig, getWhatsAppLink } from '@utils/config';
import { generateServiceSchema, generateFAQSchema, generateBreadcrumbSchema } from '@utils/seo';

const config = getConfig();

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Fisio Deportiva', url: '/fisioterapia-deportiva-valladolid/' },
  { name: 'Running', url: '/fisioterapia-deportiva-valladolid/fisioterapia-running-corredores/' },
];

const faqs = [
  {
    question: '¿Cuántas sesiones necesito para la fascitis plantar?',
    answer: 'La fascitis plantar responde generalmente en 6-10 sesiones, combinando terapia manual del pie y tobillo, trabajo sobre el tendón de Aquiles y la musculatura plantar intrínseca, ejercicios excéntricos y educación sobre la carga de entrenamiento. La clave es no interrumpir completamente el entrenamiento, sino adaptarlo.',
  },
  {
    question: '¿Puedo seguir corriendo con la rodilla del corredor?',
    answer: 'En muchos casos sí, con modificaciones. Alberto evaluará si puedes seguir corriendo y en qué volumen, o si necesitas una pausa temporal. La mayoría de casos de síndrome de la cintilla iliotibial se resuelven sin tener que parar completamente, siempre que se reduzca la carga de forma inteligente.',
  },
  {
    question: '¿La fisioterapia mejora el rendimiento en running?',
    answer: 'Indirectamente, sí. Al corregir desequilibrios musculares, mejorar la biomecánica de carrera y resolver lesiones latentes, la fisioterapia permite entrenar con mayor consistencia y menor riesgo. La constancia en el entrenamiento es el factor más importante en el rendimiento del corredor amateur.',
  },
  {
    question: '¿Hacéis análisis de la pisada o de la carrera en Valladolid?',
    answer: 'Sí, realizamos análisis biomecánico de la carrera como parte del tratamiento de las lesiones del corredor. Evaluamos la técnica de carrera, la cadencia, los patrones de apoyo y los posibles factores de riesgo biomecánico. Es una herramienta muy útil para la prevención de lesiones recurrentes.',
  },
];

const serviceSchema = generateServiceSchema({
  name: 'Fisioterapia para Corredores en Valladolid',
  description: 'Fisioterapia para runners en Valladolid: fascitis plantar, rodilla del corredor, periostitis y tendón de Aquiles. AMG Fisioterapia.',
  url: '/fisioterapia-deportiva-valladolid/fisioterapia-running-corredores/',
});

const faqSchema = generateFAQSchema(faqs);
const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);
const whatsappLink = getWhatsAppLink('Hola, soy corredor y tengo una lesión. Me gustaría pedir cita en AMG Fisioterapia.');

const lesiones = [
  { nombre: 'Síndrome de la cintilla iliotibial', desc: 'Dolor en la cara externa de la rodilla. Muy frecuente en corredores de larga distancia.' },
  { nombre: 'Fascitis plantar', desc: 'Dolor en la planta del pie, especialmente al levantarse. Una de las lesiones más frustrantes del corredor.' },
  { nombre: 'Periostitis tibial', desc: 'Dolor en la cara interna de la tibia (shin splint). Habitual en temporadas de aumento de volumen.' },
  { nombre: 'Tendinopatía de Aquiles', desc: 'Dolor y rigidez en el tendón de Aquiles. Requiere tratamiento de carga excéntrica progresiva.' },
  { nombre: 'Síndrome femoropatelar', desc: 'Dolor anterior de rodilla, detrás de la rótula. Frecuente en bajadas y en corredores con debilidad de glúteos.' },
  { nombre: 'Fracturas por estrés', desc: 'Microfracturas por sobrecarga repetida, especialmente en tibia, metatarsos y navicular.' },
];
---

<BaseLayout
  title="Fisioterapia para Corredores Valladolid | Running | AMG"
  description="Fisioterapia para runners en Valladolid: fascitis plantar, rodilla del corredor, periostitis, tendón de Aquiles. Análisis biomecánico. AMG Fisioterapia. Pide cita."
  schema={[serviceSchema, faqSchema, breadcrumbSchema]}
>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <div class="page-hero__inner">
        <div class="page-hero__text">
          <nav class="breadcrumb" aria-label="Ruta de navegación">
            <ol>
              <li><a href="/">Inicio</a></li>
              <li aria-hidden="true">›</li>
              <li><a href="/fisioterapia-deportiva-valladolid/">Fisio Deportiva</a></li>
              <li aria-hidden="true">›</li>
              <li aria-current="page">Running</li>
            </ol>
          </nav>
          <h1 class="page-hero__title font-display">Fisioterapia para Runners en Valladolid</h1>
          <p class="page-hero__subtitle">Las lesiones del corredor tienen una causa. Las encontramos, las tratamos y te ayudamos a volver a correr más fuerte y con menos riesgo de recaída.</p>
        </div>
        <div class="page-hero__image">
          <img src="/images/running.jpg" alt="Fisioterapia para corredores running Valladolid" width="800" height="500" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container content-narrow">
      <h2 class="section__title">Especialistas en Lesiones del Corredor en Valladolid</h2>
      <div class="prose">
        <p>El running es uno de los deportes más practicados en Valladolid. Corredores populares, maratonistas, trail runners, triatletas: todos comparten una pasión por el movimiento y todos, en algún momento, se encuentran con una lesión que les impide entrenar. En AMG Fisioterapia, entendemos esa frustración y trabajamos para resolver las lesiones del corredor con el rigor que merecen.</p>

        <p>El error más frecuente del corredor lesionado es esperar a que "se pase sola". Algunas lesiones se resuelven con reposo, pero muchas se cronifican si no se tratan correctamente. La fascitis plantar que se ignora durante meses, la cintilla iliotibial que reaparece cada vez que superas los 15 km, el tendón de Aquiles que cada vez tolera menos carga: estos son problemas que requieren tratamiento activo, no solo paciencia.</p>

        <p>En AMG realizamos un análisis completo del corredor: no solo tratamos la zona dolorosa, sino que buscamos los factores de riesgo biomecánicos que llevaron a la lesión. Un desequilibrio en la fuerza de los glúteos, una cadencia demasiado baja, un patrón de apoyo talón-rodilla inadecuado: estos son los "por qués" que hay que corregir para que la lesión no vuelva.</p>
      </div>
    </div>
  </section>

  <section class="section bg-cream">
    <div class="container">
      <h2 class="section__title text-center">Lesiones del Corredor que Tratamos</h2>
      <div class="lesiones-grid">
        {lesiones.map((l) => (
          <div class="lesion-card">
            <h3 class="lesion-card__title">{l.nombre}</h3>
            <p class="lesion-card__desc">{l.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container content-narrow">
      <h2 class="section__title text-center">Preguntas de Corredores</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item" name="faq-running">
            <summary class="faq-item__question">{faq.question}</summary>
            <div class="faq-item__answer"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container text-center">
      <h2 class="cta-section__title font-display">¿Lesión que te impide correr?</h2>
      <p class="cta-section__subtitle">No pierdas más entrenamientos. Pide cita en AMG Fisioterapia en Valladolid.</p>
      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir cita por WhatsApp
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero { background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-secondary-dark) 100%); color: var(--color-white); padding: calc(72px + var(--space-4xl)) 0 var(--space-4xl); }
  .page-hero__title { font-size: var(--text-5xl); color: var(--color-white); margin-bottom: var(--space-lg); max-width: 700px; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,0.8); max-width: 580px; line-height: var(--leading-relaxed); }
  .breadcrumb ol { display: flex; align-items: center; gap: var(--space-sm); list-style: none; font-size: var(--text-sm); color: rgba(255,255,255,0.6); margin-bottom: var(--space-xl); flex-wrap: wrap; }
  .breadcrumb a { color: rgba(255,255,255,0.7); }
  .bg-white { background: var(--color-white); }
  .bg-cream { background: var(--color-cream); }
  .section { padding-block: var(--space-4xl); }
  .text-center { text-align: center; }
  .content-narrow { max-width: 800px; margin-inline: auto; }
  .section__title { font-size: var(--text-3xl); font-weight: 700; color: var(--color-gray-900); margin-bottom: var(--space-xl); }
  .prose p { font-size: var(--text-base); line-height: var(--leading-relaxed); color: var(--text-secondary); margin-bottom: var(--space-lg); }
  .lesiones-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-lg); margin-top: var(--space-2xl); }
  .lesion-card { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-lg); padding: var(--space-xl); }
  .lesion-card__title { font-size: var(--text-base); font-weight: 700; color: var(--color-gray-900); margin-bottom: var(--space-sm); }
  .lesion-card__desc { font-size: var(--text-sm); color: var(--text-secondary); line-height: var(--leading-relaxed); }
  .faq-list { display: flex; flex-direction: column; gap: var(--space-md); }
  .faq-item { background: var(--color-cream); border: 1px solid var(--color-gray-200); border-radius: var(--radius-lg); overflow: hidden; }
  .faq-item__question { padding: var(--space-lg) var(--space-xl); font-size: var(--text-base); font-weight: 600; color: var(--color-gray-900); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: var(--space-md); }
  .faq-item__question::-webkit-details-marker { display: none; }
  .faq-item__question::after { content: '+'; font-size: var(--text-xl); color: var(--color-primary); flex-shrink: 0; transition: transform var(--duration-fast); }
  .faq-item[open] .faq-item__question::after { transform: rotate(45deg); }
  .faq-item__answer { padding: 0 var(--space-xl) var(--space-lg); }
  .faq-item__answer p { font-size: var(--text-sm); color: var(--text-secondary); line-height: var(--leading-relaxed); }
  .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); }
  .cta-section__title { font-size: var(--text-4xl); color: var(--color-white); margin-bottom: var(--space-md); }
  .cta-section__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,0.85); margin-bottom: var(--space-2xl); }
  .btn-whatsapp { display: inline-flex; align-items: center; gap: var(--space-sm); padding: var(--space-md) var(--space-2xl); background: var(--color-white); color: var(--color-primary-dark); font-weight: 700; font-size: var(--text-base); border-radius: var(--radius-full); transition: all var(--duration-fast); }
  .btn-whatsapp:hover { background: var(--color-gray-100); transform: translateY(-2px); }
  @media (max-width: 1024px) { .lesiones-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .page-hero__title { font-size: var(--text-3xl); } .lesiones-grid { grid-template-columns: 1fr; } }
  .page-hero__inner { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; align-items: center; }
  .page-hero__image { border-radius: 20px; overflow: hidden; flex-shrink: 0; }
  .page-hero__image img { width: 100%; height: 360px; object-fit: cover; display: block; }
  @media (max-width: 900px) { .page-hero__inner { grid-template-columns: 1fr; } .page-hero__image { display: none; } }
</style>
