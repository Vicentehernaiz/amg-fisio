---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getConfig, getWhatsAppLink } from '@utils/config';
import { generateServiceSchema, generateFAQSchema, generateBreadcrumbSchema } from '@utils/seo';

const config = getConfig();

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Servicios', url: '/servicios-fisioterapia/' },
  { name: 'Fisioterapia de Cadera', url: '/servicios-fisioterapia/rehabilitacion-cadera-valladolid/' },
];

const faqs = [
  {
    question: '¿Cuánto tarda la recuperación de la bursitis de cadera?',
    answer: 'La bursitis trocantérea (trocanteritis) suele responder en 6-10 sesiones de fisioterapia, combinando técnicas manuales, trabajo sobre los glúteos y educación postural. Casos más cronificados pueden requerir más sesiones. La recuperación completa puede llevar 4-8 semanas.',
  },
  {
    question: '¿Qué es el conflicto femoroacetabular?',
    answer: 'El conflicto femoroacetabular (FAI) es una alteración morfológica de la cadera (exceso de hueso en la cabeza femoral o en el acetábulo) que provoca pinzamiento de los tejidos blandos durante el movimiento. Produce dolor inguinal al flexionar la cadera. La fisioterapia puede controlar los síntomas en muchos casos; en otros requiere artroscopia.',
  },
  {
    question: '¿Cuándo se necesita una prótesis de cadera?',
    answer: 'La prótesis total de cadera está indicada en artrosis avanzada que no responde al tratamiento conservador, con dolor severo y limitación funcional importante. La fisioterapia preoperatoria (prehabilitación) mejora los resultados quirúrgicos, y la fisioterapia postoperatoria es indispensable para recuperar la movilidad y la fuerza.',
  },
  {
    question: '¿La fisioterapia puede evitar la cirugía de cadera?',
    answer: 'En muchos casos sí, especialmente en artrosis moderada, bursitis, trocanteritis, tendinopatías y conflicto femoroacetabular leve. Un programa de fisioterapia bien diseñado puede reducir el dolor, mejorar la función y posponer significativamente (o evitar) la necesidad de cirugía.',
  },
  {
    question: '¿Cuánto tiempo dura la rehabilitación de una prótesis de cadera?',
    answer: 'La rehabilitación post-prótesis de cadera suele durar entre 3 y 6 meses. La primera fase (hospitalaria) dura 3-5 días. La segunda fase (ambulatoria) se extiende durante 2-3 meses, trabajando la marcha, el rango de movimiento y la fuerza. La recuperación funcional completa puede llevar hasta 6 meses.',
  },
];

const serviceSchema = generateServiceSchema({
  name: 'Fisioterapia de Cadera en Valladolid',
  description: 'Tratamiento del dolor de cadera en Valladolid: bursitis, trocanteritis, conflicto femoroacetabular y rehabilitación post-prótesis. AMG Fisioterapia.',
  url: '/servicios-fisioterapia/rehabilitacion-cadera-valladolid/',
});

const faqSchema = generateFAQSchema(faqs);
const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);
const whatsappLink = getWhatsAppLink('Hola, tengo dolor de cadera y me gustaría pedir cita en AMG Fisioterapia.');
---

<BaseLayout
  title="Fisioterapia de Cadera Valladolid | AMG Fisioterapia"
  description="Fisioterapia para el dolor de cadera en Valladolid: bursitis, trocanteritis, artrosis y post-prótesis. Tratamiento personalizado. Alberto Muñoz González. 35€/sesión."
  schema={[serviceSchema, faqSchema, breadcrumbSchema]}
>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <div class="page-hero__inner">
        <div class="page-hero__text">
          <nav class="breadcrumb" aria-label="Ruta de navegación">
            <ol>
              <li><a href="/">Inicio</a></li>
              <li aria-hidden="true">›</li>
              <li><a href="/servicios-fisioterapia/">Servicios</a></li>
              <li aria-hidden="true">›</li>
              <li aria-current="page">Fisioterapia de Cadera</li>
            </ol>
          </nav>
          <h1 class="page-hero__title font-display">Fisioterapia de Cadera en Valladolid</h1>
          <p class="page-hero__subtitle">El dolor de cadera limita la marcha, el deporte y las actividades cotidianas. Con el tratamiento adecuado en Valladolid, podemos recuperar tu movilidad y calidad de vida.</p>
        </div>
        <div class="page-hero__image">
          <img src="/images/rehabilitacion.jpg" alt="Rehabilitación cadera fisioterapia Valladolid" width="800" height="500" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container content-narrow">
      <h2 class="section__title">Patologías de Cadera que Tratamos en Valladolid</h2>
      <div class="prose">
        <p>La cadera es la articulación que conecta el tronco con la extremidad inferior y soporta todo el peso del cuerpo. Cuando duele, afecta a casi todo: la marcha, la capacidad de subir escaleras, el deporte y el simple hecho de levantarse de una silla. En AMG Fisioterapia abordamos el dolor de cadera de forma integral, buscando la causa real del problema, no solo tratando el síntoma.</p>

        <h3>Bursitis Trocantérea (Trocanteritis)</h3>
        <p>La bursitis trocantérea, también llamada trocanteritis, es la inflamación de la bursa sinovial que protege el trocánter mayor del fémur. Produce dolor en la cara externa de la cadera que empeora al caminar, al subir escaleras o al tumbarse sobre el lado afectado. Es más frecuente en mujeres de mediana edad y en corredores. La fisioterapia consigue excelentes resultados: trabajo sobre los glúteos y los rotadores externos, técnicas manuales y educación postural.</p>

        <h3>Conflicto Femoroacetabular</h3>
        <p>El pinzamiento o conflicto femoroacetabular (FAI) produce dolor inguinal al flexionar la cadera, especialmente al sentarse, al ponerse en cuclillas o al pedalear. Se debe a una alteración morfológica de la articulación. La fisioterapia puede mejorar significativamente los síntomas trabajando la movilidad articular, la musculatura estabilizadora y los patrones de movimiento.</p>

        <h3>Tendinopatía de los Glúteos</h3>
        <p>Las tendinopatías del glúteo medio y mayor son causas frecuentes de dolor lateral de cadera. Se tratan eficazmente con ejercicio terapéutico excéntrico y técnicas de carga progresiva del tendón, evitando los movimientos que agravan el problema (cruzar las piernas, sentarse con las rodillas caídas hacia dentro).</p>

        <h3>Artrosis de Cadera y Prótesis</h3>
        <p>La coxartrosis (artrosis de cadera) es el desgaste del cartílago articular que produce dolor y rigidez progresivos. En estadios iniciales y moderados, la fisioterapia puede controlar los síntomas y mejorar la función durante años. En estadios avanzados, cuando la cirugía de prótesis total es necesaria, ofrecemos tanto la prehabilitación (preparación preoperatoria) como la rehabilitación postoperatoria completa.</p>

        <p>En Valladolid, AMG Fisioterapia trabaja en estrecha coordinación con traumatólogos y cirujanos ortopédicos para garantizar la continuidad asistencial del paciente con patología de cadera.</p>
      </div>
    </div>
  </section>

  <section class="section bg-cream">
    <div class="container content-narrow">
      <h2 class="section__title text-center">Preguntas sobre la Fisioterapia de Cadera</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item" name="faq-cadera">
            <summary class="faq-item__question">{faq.question}</summary>
            <div class="faq-item__answer"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container text-center">
      <h2 class="cta-section__title font-display">¿Tienes dolor de cadera?</h2>
      <p class="cta-section__subtitle">Pide tu valoración en AMG Fisioterapia en Valladolid. Tratamiento personalizado desde 35€/sesión.</p>
      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir cita por WhatsApp
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero { background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-secondary-dark) 100%); color: var(--color-white); padding: calc(72px + var(--space-4xl)) 0 var(--space-4xl); }
  .page-hero__title { font-size: var(--text-5xl); color: var(--color-white); margin-bottom: var(--space-lg); max-width: 700px; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,0.8); max-width: 580px; line-height: var(--leading-relaxed); }
  .breadcrumb ol { display: flex; align-items: center; gap: var(--space-sm); list-style: none; font-size: var(--text-sm); color: rgba(255,255,255,0.6); margin-bottom: var(--space-xl); flex-wrap: wrap; }
  .breadcrumb a { color: rgba(255,255,255,0.7); }
  .bg-white { background: var(--color-white); }
  .bg-cream { background: var(--color-cream); }
  .section { padding-block: var(--space-4xl); }
  .text-center { text-align: center; }
  .content-narrow { max-width: 800px; margin-inline: auto; }
  .section__title { font-size: var(--text-3xl); font-weight: 700; color: var(--color-gray-900); margin-bottom: var(--space-xl); }
  .prose p { font-size: var(--text-base); line-height: var(--leading-relaxed); color: var(--text-secondary); margin-bottom: var(--space-lg); }
  .prose h3 { font-size: var(--text-xl); font-weight: 700; color: var(--color-gray-900); margin-top: var(--space-2xl); margin-bottom: var(--space-md); }
  .faq-list { display: flex; flex-direction: column; gap: var(--space-md); }
  .faq-item { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-lg); overflow: hidden; }
  .faq-item__question { padding: var(--space-lg) var(--space-xl); font-size: var(--text-base); font-weight: 600; color: var(--color-gray-900); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: var(--space-md); }
  .faq-item__question::-webkit-details-marker { display: none; }
  .faq-item__question::after { content: '+'; font-size: var(--text-xl); color: var(--color-primary); flex-shrink: 0; transition: transform var(--duration-fast); }
  .faq-item[open] .faq-item__question::after { transform: rotate(45deg); }
  .faq-item__answer { padding: 0 var(--space-xl) var(--space-lg); }
  .faq-item__answer p { font-size: var(--text-sm); color: var(--text-secondary); line-height: var(--leading-relaxed); }
  .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); }
  .cta-section__title { font-size: var(--text-4xl); color: var(--color-white); margin-bottom: var(--space-md); }
  .cta-section__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,0.85); margin-bottom: var(--space-2xl); }
  .btn-whatsapp { display: inline-flex; align-items: center; gap: var(--space-sm); padding: var(--space-md) var(--space-2xl); background: var(--color-white); color: var(--color-primary-dark); font-weight: 700; font-size: var(--text-base); border-radius: var(--radius-full); transition: all var(--duration-fast); }
  .btn-whatsapp:hover { background: var(--color-gray-100); transform: translateY(-2px); }
  @media (max-width: 640px) { .page-hero__title { font-size: var(--text-3xl); } }
  .page-hero__inner { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; align-items: center; }
  .page-hero__image { border-radius: 20px; overflow: hidden; flex-shrink: 0; }
  .page-hero__image img { width: 100%; height: 360px; object-fit: cover; display: block; }
  @media (max-width: 900px) { .page-hero__inner { grid-template-columns: 1fr; } .page-hero__image { display: none; } }
</style>
