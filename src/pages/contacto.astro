---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getConfig, getWhatsAppLink, getPhoneLink, getEmailLink } from '@utils/config';
import { generateBreadcrumbSchema } from '@utils/seo';

const config = getConfig();

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Contacto', url: '/contacto/' },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);
const whatsappLink = getWhatsAppLink('Hola, me gustaría pedir cita en AMG Fisioterapia.');
---

<BaseLayout
  title="Contacto | Pedir Cita Fisioterapia Valladolid | AMG"
  description="Contacta con AMG Fisioterapia en Valladolid. WhatsApp, teléfono, email y dirección. Horarios: L-V 9-14h / 16-20h, Sábados 9-14h. Pide cita ahora."
  schema={[breadcrumbSchema]}
>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Ruta de navegación">
        <ol>
          <li><a href="/">Inicio</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page">Contacto</li>
        </ol>
      </nav>
      <h1 class="page-hero__title font-display">Contacta con AMG Fisioterapia</h1>
      <p class="page-hero__subtitle">Pide cita, resuelve tus dudas o cuéntanos tu caso. Respondemos rápido.</p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="contact-grid">

        <!-- WhatsApp CTA Principal -->
        <div class="contact-main">
          <h2 class="contact-main__title font-display">La forma más rápida</h2>
          <p class="contact-main__subtitle">Escríbenos por WhatsApp y te responderemos lo antes posible. Puedes enviarnos también fotos de pruebas médicas o describirnos tu caso.</p>
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-whatsapp-large">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Escribir por WhatsApp
          </a>
          <p class="contact-main__hours">Atendemos WhatsApp: {config.hours.whatsappHours}</p>
        </div>

        <!-- Datos de contacto -->
        <div class="contact-info">
          <h2 class="contact-info__title">Datos de Contacto</h2>

          <div class="contact-item">
            <div class="contact-item__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div>
              <p class="contact-item__label">Teléfono</p>
              <a href={getPhoneLink()} class="contact-item__value">{config.contact.phoneDisplay}</a>
              <p class="contact-item__note">Horario de llamadas: {config.hours.callHours}</p>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <p class="contact-item__label">Email</p>
              <a href={getEmailLink()} class="contact-item__value">{config.contact.email}</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="contact-item__label">Dirección</p>
              <a href={config.contact.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="contact-item__value">
                {config.contact.address.street}<br />{config.contact.address.postalCode} {config.contact.address.city}
              </a>
              <div class="map-links">
                <a href={config.contact.googleMapsUrl} target="_blank" rel="noopener noreferrer">Google Maps</a>
                <a href={config.contact.appleMapsUrl} target="_blank" rel="noopener noreferrer">Apple Maps</a>
              </div>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="contact-item__label">Horarios</p>
              {config.hours.schedule.map((s) => (
                <div class="hours-row">
                  <span class="hours-row__days">{s.days}:</span>
                  <span class="hours-row__time">{s.hours}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-cream">
    <div class="container">
      <h2 class="section__title text-center">Cómo Llegar</h2>
      <div class="map-section">
        <div class="map-placeholder">
          <p>Ubicados en el centro de Valladolid.</p>
          <a href={config.contact.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="map-cta">
            Ver en Google Maps →
          </a>
        </div>
        <div class="directions">
          <h3>Indicaciones para Llegar</h3>
          <p>AMG Fisioterapia se encuentra en el centro de Valladolid, bien comunicado con transporte público. Hay paradas de autobús urbano a menos de 5 minutos a pie y zona de aparcamiento en los alrededores.</p>
          <p>Si vienes en transporte público: consulta las líneas de autobús urbano de Valladolid que pasan por la zona centro.</p>
          <p>Si vienes en coche: el parking más cercano está en [indicar parking]. También hay zona azul y verde en las calles adyacentes.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container text-center">
      <h2 class="cta-section__title font-display">¿Tienes dudas antes de pedir cita?</h2>
      <p class="cta-section__subtitle">Escríbenos por WhatsApp y te resolvemos cualquier pregunta sin compromiso.</p>
      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Escribir por WhatsApp
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero { background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-secondary-dark) 100%); color: var(--color-white); padding: calc(72px + var(--space-4xl)) 0 var(--space-4xl); }
  .page-hero__title { font-size: var(--text-5xl); color: var(--color-white); margin-bottom: var(--space-lg); max-width: 700px; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,0.8); max-width: 580px; line-height: var(--leading-relaxed); }
  .breadcrumb ol { display: flex; align-items: center; gap: var(--space-sm); list-style: none; font-size: var(--text-sm); color: rgba(255,255,255,0.6); margin-bottom: var(--space-xl); }
  .breadcrumb a { color: rgba(255,255,255,0.7); }
  .bg-white { background: var(--color-white); }
  .bg-cream { background: var(--color-cream); }
  .section { padding-block: var(--space-4xl); }
  .text-center { text-align: center; }
  .content-narrow { max-width: 800px; margin-inline: auto; }
  .section__title { font-size: var(--text-3xl); font-weight: 700; color: var(--color-gray-900); margin-bottom: var(--space-xl); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4xl); align-items: start; }
  .contact-main { background: var(--color-secondary); border-radius: var(--radius-2xl); padding: var(--space-3xl); }
  .contact-main__title { font-size: var(--text-3xl); color: var(--color-white); margin-bottom: var(--space-md); }
  .contact-main__subtitle { font-size: var(--text-base); color: rgba(255,255,255,0.8); line-height: var(--leading-relaxed); margin-bottom: var(--space-2xl); }
  .btn-whatsapp-large { display: inline-flex; align-items: center; gap: var(--space-md); padding: var(--space-lg) var(--space-2xl); background: #25D366; color: var(--color-white); font-weight: 700; font-size: var(--text-lg); border-radius: var(--radius-full); transition: all var(--duration-fast); }
  .btn-whatsapp-large:hover { background: #1ebe5d; transform: translateY(-2px); }
  .contact-main__hours { margin-top: var(--space-lg); font-size: var(--text-sm); color: rgba(255,255,255,0.6); }
  .contact-info { display: flex; flex-direction: column; gap: var(--space-2xl); }
  .contact-info__title { font-size: var(--text-2xl); font-weight: 700; color: var(--color-gray-900); margin-bottom: var(--space-lg); }
  .contact-item { display: flex; gap: var(--space-lg); align-items: flex-start; }
  .contact-item__icon { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: var(--color-primary-50); border-radius: var(--radius-lg); color: var(--color-primary); flex-shrink: 0; margin-top: 2px; }
  .contact-item__label { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--tracking-wider); color: var(--text-tertiary); margin-bottom: 4px; }
  .contact-item__value { font-size: var(--text-base); font-weight: 600; color: var(--color-gray-900); transition: color var(--duration-fast); }
  .contact-item__value:hover { color: var(--color-primary); }
  .contact-item__note { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 4px; }
  .map-links { display: flex; gap: var(--space-md); margin-top: var(--space-sm); }
  .map-links a { font-size: var(--text-sm); color: var(--color-primary); text-decoration: underline; }
  .hours-row { display: flex; gap: var(--space-md); font-size: var(--text-sm); margin-bottom: 4px; }
  .hours-row__days { color: var(--text-secondary); min-width: 120px; }
  .hours-row__time { color: var(--color-gray-900); font-weight: 500; }
  .map-section { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3xl); margin-top: var(--space-2xl); }
  .map-placeholder { background: var(--color-gray-200); border-radius: var(--radius-xl); height: 300px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-md); }
  .map-placeholder p { color: var(--text-secondary); }
  .map-cta { display: inline-flex; align-items: center; height: 44px; padding: 0 var(--space-xl); background: linear-gradient(27deg, #8BAD44 17%, #95B44E 37%, #B1C96B 72%, #C4D87F 92%); color: #181428; border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600; box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.05), 0px 5px 29.2px 0px rgba(218,211,198,0.32); transition: opacity 0.15s, transform 0.15s; }
  .map-cta:hover { opacity: 0.9; transform: translateY(-1px); }
  .directions h3 { font-size: var(--text-xl); font-weight: 700; color: var(--color-gray-900); margin-bottom: var(--space-lg); }
  .directions p { font-size: var(--text-base); color: var(--text-secondary); line-height: var(--leading-relaxed); margin-bottom: var(--space-md); }
  .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); }
  .cta-section__title { font-size: var(--text-4xl); color: var(--color-white); margin-bottom: var(--space-md); }
  .cta-section__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,0.85); margin-bottom: var(--space-2xl); }
  .btn-whatsapp { display: inline-flex; align-items: center; gap: var(--space-sm); padding: var(--space-md) var(--space-2xl); background: var(--color-white); color: var(--color-primary-dark); font-weight: 700; font-size: var(--text-base); border-radius: var(--radius-full); transition: all var(--duration-fast); }
  .btn-whatsapp:hover { background: var(--color-gray-100); transform: translateY(-2px); }
  @media (max-width: 1024px) { .contact-grid { grid-template-columns: 1fr; } .map-section { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { .page-hero__title { font-size: var(--text-3xl); } }
</style>
