</style>

<script>
(function() {
  // Respect prefers-reduced-motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  // ---- Load GSAP + ScrollTrigger from CDN ----
  function loadScript(src) {
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = src;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  async function initGSAP() {
    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js');
    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js');

    const gsap = window.gsap;
    const ScrollTrigger = window.ScrollTrigger;
    gsap.registerPlugin(ScrollTrigger);

    // ---- HERO animations ----
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    tl.to('.hero__eyebrow', { opacity: 1, duration: 0.6 })
      .to('.hero__word', {
        opacity: 1,
        y: 0,
        duration: 0.7,
        stagger: 0.12,
      }, '-=0.2')
      .to('.hero__subtitle', { opacity: 1, y: 0, duration: 0.6 }, '-=0.3')
      .to('.hero__stats',    { opacity: 1, duration: 0.5 }, '-=0.2')
      .to('.hero__ctas',     { opacity: 1, duration: 0.5 }, '-=0.2')
      .to('.hero__pain-card',{ opacity: 1, x: 0, duration: 0.7 }, '-=0.4');

    // ---- Hero parallax ----
    const heroBg = document.getElementById('hero-bg');
    if (heroBg) {
      ScrollTrigger.create({
        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
        onUpdate: (self) => {
          gsap.set(heroBg, { yPercent: self.progress * 20 });
        }
      });
    }

    // ---- Scroll reveal: sections ----
    document.querySelectorAll('.gs-reveal').forEach((el) => {
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.9,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          once: true,
        }
      });
    });

    // ---- Stagger: service cards ----
    document.querySelectorAll('.gs-stagger').forEach((el, i) => {
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: 'power2.out',
        delay: i * 0.08,
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          once: true,
        }
      });
    });

    // ---- Stats counter ----
    document.querySelectorAll('.stat-value').forEach((el) => {
      const target = parseFloat(el.dataset.target || '0');
      const prefix = el.dataset.prefix || '';
      const suffix = el.dataset.suffix || '';
      const isDecimal = el.dataset.decimal === 'true';

      ScrollTrigger.create({
        trigger: el,
        start: 'top 80%',
        once: true,
        onEnter: () => {
          gsap.fromTo(
            { val: 0 },
            { val: target, duration: 2, ease: 'power2.out',
              onUpdate: function() {
                const v = this.targets()[0].val;
                el.textContent = prefix + (isDecimal ? v.toFixed(1) : Math.round(v).toLocaleString('es-ES')) + suffix;
              }
            }
          );
        }
      });
    });

    // header scroll shadow handled via CSS .scrolled class (see Header.astro)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGSAP);
  } else {
    initGSAP();
  }

  // ---- Techniques Carousel (no GSAP needed) ----
  const track = document.getElementById('techniques-track');
  const dots  = document.querySelectorAll('.techniques-dot');
  const prevBtn = document.getElementById('tech-prev');
  const nextBtn = document.getElementById('tech-next');

  if (track && dots.length) {
    let current = 0;
    const slides = track.querySelectorAll('.technique-slide');
    const total = slides.length;

    function goTo(index) {
      current = (index + total) % total;
      const slideWidth = slides[0].offsetWidth + parseInt(getComputedStyle(track).gap);
      track.scrollTo({ left: current * slideWidth, behavior: 'smooth' });
      dots.forEach((d, i) => {
        d.classList.toggle('active', i === current);
        d.setAttribute('aria-selected', String(i === current));
      });
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

    // Update dot on scroll
    let scrollTimer;
    track.addEventListener('scroll', () => {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => {
        const slideWidth = slides[0].offsetWidth + parseInt(getComputedStyle(track).gap);
        current = Math.round(track.scrollLeft / slideWidth);
        dots.forEach((d, i) => {
          d.classList.toggle('active', i === current);
          d.setAttribute('aria-selected', String(i === current));
        });
      }, 100);
    });
  }

  // ---- Bonos Calculator ----
  const bonosCard = document.querySelector('.pricing-card--bonos');
  if (bonosCard) {
    const tiers = JSON.parse(bonosCard.dataset.tiers || '[]');
    let sessions = 5;
    const MIN = 1, MAX = 30;

    const calcWrap = bonosCard.querySelector('.bonos-calc-wrap');
    const toggleBtn = bonosCard.querySelector('.bonos-toggle-btn');
    const countEl = bonosCard.querySelector('.bonos-calc__count');
    const tierNameEl = bonosCard.querySelector('.bonos-calc__tier-name');
    const totalEl = bonosCard.querySelector('.bonos-calc__total');
    const perSessionEl = bonosCard.querySelector('.bonos-calc__per-session');
    const savingsEl = bonosCard.querySelector('.bonos-calc__savings');
    const waBtn = bonosCard.querySelector('.bonos-wa-btn');
    const minusBtn = bonosCard.querySelector('.bonos-step--minus');
    const plusBtn = bonosCard.querySelector('.bonos-step--plus');

    // Toggle calculator visibility
    toggleBtn?.addEventListener('click', () => {
      const isOpen = calcWrap?.classList.toggle('is-open');
      if (toggleBtn) {
        toggleBtn.setAttribute('aria-expanded', String(isOpen));
        toggleBtn.textContent = isOpen ? 'Ocultar calculadora' : 'Configurar bonos';
      }
      if (calcWrap) calcWrap.setAttribute('aria-hidden', String(!isOpen));
    });

    function getActiveTier(n) {
      let active = tiers[0];
      for (const tier of tiers) {
        if (n >= tier.sessions) active = tier;
      }
      return active;
    }

    function updateCalc() {
      if (!countEl || !tierNameEl || !totalEl || !perSessionEl || !savingsEl || !waBtn) return;
      const tier = getActiveTier(sessions);
      const total = sessions * tier.pricePerSession;
      const basePrice = tiers[0]?.pricePerSession || tier.pricePerSession;
      const saved = sessions * (basePrice - tier.pricePerSession);

      countEl.textContent = String(sessions);
      tierNameEl.textContent = tier.label;
      totalEl.textContent = total + ' €';
      perSessionEl.textContent = tier.pricePerSession + ' €/sesión';
      savingsEl.textContent = saved > 0 ? `Ahorras ${saved} € vs sesión suelta` : 'Sin descuento adicional';

      const waNum = (bonosCard.dataset.wa || '+34600000000').replace(/\s/g, '');
      const msg = encodeURIComponent(`Hola, me interesa un bono de ${sessions} sesiones (${total} €). ¿Podéis confirmar disponibilidad?`);
      waBtn.href = `https://wa.me/${waNum}?text=${msg}`;

      if (minusBtn) minusBtn.disabled = sessions <= MIN;
      if (plusBtn) plusBtn.disabled = sessions >= MAX;
    }

    minusBtn?.addEventListener('click', () => { sessions = Math.max(MIN, sessions - 1); updateCalc(); });
    plusBtn?.addEventListener('click', () => { sessions = Math.min(MAX, sessions + 1); updateCalc(); });

    updateCalc();
  }
})();
</script>
