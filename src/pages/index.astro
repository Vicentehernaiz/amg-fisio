---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getConfig, getWhatsAppLink, getPhoneLink } from '@utils/config';
import { Star } from '@lucide/astro';

const config = getConfig();
const waLink = getWhatsAppLink('Hola, me gustaría reservar una primera consulta en AMG Fisioterapia.');
const waClinLink = getWhatsAppLink('Hola, me gustaría reservar una sesión en clínica.');
const waDomLink = getWhatsAppLink('Hola, me gustaría reservar una sesión a domicilio.');

// Bono starting price: first tier with sessions > 1
const bonoTiers = config.pricing.bonos.tiers || [];
const bonoMinTier = bonoTiers.find((t) => t.sessions > 1) || bonoTiers[0];
const bonoMinPrice = bonoMinTier ? bonoMinTier.sessions * bonoMinTier.pricePerSession : 0;
---

<BaseLayout
  title="AMG Fisioterapia | Fisioterapia Avanzada en Valladolid Centro"
  description="Clínica de fisioterapia en Valladolid Centro. Especialistas en fisioterapia deportiva, dolor de espalda, rehabilitación y más. Sesiones de 45-60 min personalizadas. Pide cita."
>
  <Header slot="header" />

  <!-- ====================================================
       1. HERO — Fullscreen con parallax y GSAP stagger
  ===================================================== -->
  <section class="hero" id="inicio" aria-label="Inicio">
    <div class="hero__bg" id="hero-bg">
      <img src="/images/hero-bg.jpg" alt="" role="presentation" loading="eager" fetchpriority="high" />
      <div class="hero__overlay"></div>
    </div>

    <div class="container hero__content">
      <div class="hero__left">
        <p class="hero__eyebrow font-display">AMG Fisioterapia · Valladolid Centro</p>
        <h1 class="hero__title" id="hero-title">
          <span class="hero__word">Fisioterapia</span>
          <span class="hero__word hero__word--accent">Avanzada</span>
          <span class="hero__word">en</span>
          <span class="hero__word hero__word--accent">Valladolid</span>
        </h1>
        <p class="hero__subtitle" id="hero-subtitle">
          Tratamientos personalizados. Sin interrupciones. Solo tú y tu recuperación.
        </p>

        <div class="hero__stats" id="hero-stats">
          <div class="hero__stat">
            <span class="hero__stat-value">{config.stats.sessionDuration}</span>
            <span class="hero__stat-label">sesiones exclusivas</span>
          </div>
          <div class="hero__stat-divider" aria-hidden="true"></div>
          <div class="hero__stat">
            <span class="hero__stat-value">{config.stats.patientsSatisfied}</span>
            <span class="hero__stat-label">pacientes satisfechos</span>
          </div>
          <div class="hero__stat-divider" aria-hidden="true"></div>
          <div class="hero__stat">
            <span class="hero__stat-value">{config.stats.googleRating}<span class="hero__star">★</span></span>
            <span class="hero__stat-label">valoración Google</span>
          </div>
        </div>

        <div class="hero__ctas" id="hero-ctas">
          <button class="hero__cta-primary" type="button">
            Reservar tu cita
          </button>
        </div>
      </div>

      <div class="hero__right" id="hero-pain">
        <div class="hero__pain-card">
          <p class="hero__pain-label">¿Qué te duele hoy?</p>
          <div class="hero__pain-grid">
            <a href="/servicios-fisioterapia/cervicalgia-dolor-cervical-valladolid/" class="pain-btn">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="4" r="2"/><path d="M12 6v6M9 10l3 2 3-2M7 17c0-2.5 2-4 5-4s5 1.5 5 4"/></svg>
              <span>Cuello</span>
            </a>
            <a href="/servicios-fisioterapia/dolor-lumbar-lumbalgia-valladolid/" class="pain-btn">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2c0 0-4 4-4 9s4 9 4 9 4-4 4-9-4-9-4-9"/><path d="M8 9h8M8 13h8"/></svg>
              <span>Espalda</span>
            </a>
            <a href="/servicios-fisioterapia/rehabilitacion-rodilla-valladolid/" class="pain-btn">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 3v18M8 7l4-4 4 4M8 17l4 4 4-4"/><circle cx="12" cy="12" r="3"/></svg>
              <span>Rodilla</span>
            </a>
            <a href="/servicios-fisioterapia/rehabilitacion-cadera-valladolid/" class="pain-btn">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 12c0-3.9 3.1-7 7-7s7 3.1 7 7-3.1 7-7 7"/><path d="M12 5v14"/></svg>
              <span>Cadera</span>
            </a>
            <a href="/fisioterapia-deportiva-valladolid/" class="pain-btn">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="5" r="2"/><path d="M12 7v5l3 3M9 12l-3 4M15 12l3 4"/></svg>
              <span>Hombro</span>
            </a>
            <a href="/fisioterapia-deportiva-valladolid/" class="pain-btn">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2v10M8 16l4 6 4-6"/><circle cx="12" cy="14" r="3"/></svg>
              <span>Tobillo</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll" aria-hidden="true">
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ====================================================
       2. SERVICIOS — Grid 3 columnas premium
  ===================================================== -->
  <section class="services section gs-reveal" id="servicios" aria-label="Servicios de fisioterapia">
    <div class="container">
      <div class="section-header">
        <p class="section-eyebrow font-display">Especialidades</p>
        <h2 class="section-title">Tratamos la causa,<br>no solo el síntoma</h2>
        <p class="section-subtitle">Fisioterapia avanzada para cada tipo de lesión y paciente</p>
      </div>

      <div class="services-grid stagger-grid">
        <a href="/fisioterapia-deportiva-valladolid/" class="service-card gs-stagger">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="5" r="2"/><path d="m6.5 17.5 3-7 5 0 3 7"/><path d="M3 21h18"/></svg>
          </div>
          <h3 class="service-card__title">Fisioterapia Deportiva</h3>
          <p class="service-card__desc">Especialistas en readaptación, esguinces, ligamento cruzado y vuelta al deporte.</p>
          <span class="service-card__arrow">Ver más →</span>
        </a>

        <a href="/servicios-fisioterapia/" class="service-card gs-stagger">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C8 2 4 6 4 12s4 10 8 10 8-4 8-10S16 2 12 2"/><path d="M12 6v12M8 10h8M8 14h6"/></svg>
          </div>
          <h3 class="service-card__title">Columna y Dolor Crónico</h3>
          <p class="service-card__desc">Cervicalgias, lumbalgias, hernias discales y ciáticas con tratamiento personalizado.</p>
          <span class="service-card__arrow">Ver más →</span>
        </a>

        <a href="/servicios-fisioterapia/rehabilitacion-neurologica-valladolid/" class="service-card gs-stagger">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>
          </div>
          <h3 class="service-card__title">Rehabilitación Neurológica</h3>
          <p class="service-card__desc">Recuperación tras ictus, Parkinson, esclerosis múltiple. Recupera tu independencia.</p>
          <span class="service-card__arrow">Ver más →</span>
        </a>

        <a href="/servicios-fisioterapia/fisioterapia-rodilla-valladolid/" class="service-card gs-stagger">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v4M16 2v4M4 8h16M4 8v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 14h4M12 12v4"/></svg>
          </div>
          <h3 class="service-card__title">Traumatología y Post-Cirugía</h3>
          <p class="service-card__desc">Rehabilitación post-operatoria de rodilla, cadera, hombro y otras articulaciones.</p>
          <span class="service-card__arrow">Ver más →</span>
        </a>

        <a href="/fisioterapia-domicilio-valladolid/" class="service-card gs-stagger">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="service-card__title">Fisioterapia a Domicilio</h3>
          <p class="service-card__desc">Nos desplazamos a tu casa en Valladolid y provincia. 45€/sesión, todo incluido.</p>
          <span class="service-card__arrow">Ver más →</span>
        </a>

        <a href="/servicios-fisioterapia/" class="service-card service-card--cta gs-stagger">
          <div class="service-card__all">
            <p class="service-card__all-label font-display">Ver todos los servicios</p>
            <span class="service-card__all-arrow">→</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ====================================================
       3. TÉCNICAS — Carousel horizontal scroll-snap
  ===================================================== -->
  <section class="techniques section gs-reveal" id="tecnicas" aria-label="Técnicas de fisioterapia">
    <div class="container">
      <div class="section-header">
        <p class="section-eyebrow font-display">Técnicas</p>
        <h2 class="section-title">Tratamientos especializados<br>con evidencia científica</h2>
      </div>
    </div>

    <div class="techniques-wrapper">
      <div class="techniques-track" id="techniques-track" role="list">
        <div class="technique-slide" role="listitem">
          <div class="technique-slide__img">
            <img src="/images/terapia-manual.png" alt="Terapia manual avanzada en AMG Fisioterapia Valladolid" loading="lazy" width="400" height="280" />
          </div>
          <div class="technique-slide__body">
            <span class="technique-slide__num font-display">01</span>
            <h3 class="technique-slide__title">Terapia Manual</h3>
            <p class="technique-slide__desc">Técnicas manuales específicas para recuperar la movilidad y reducir el dolor. Movilizaciones articulares, masoterapia y manipulaciones vertebrales.</p>
            <a href="/tecnicas-fisioterapia/terapia-manual/" class="technique-slide__link">Saber más →</a>
          </div>
        </div>

        <div class="technique-slide" role="listitem">
          <div class="technique-slide__img">
            <img src="/images/ejercicio-terapeutico.jpg" alt="Ejercicio terapéutico personalizado en Valladolid" loading="lazy" width="400" height="280" />
          </div>
          <div class="technique-slide__body">
            <span class="technique-slide__num font-display">02</span>
            <h3 class="technique-slide__title">Ejercicio Terapéutico</h3>
            <p class="technique-slide__desc">Ejercicios personalizados para fortalecer y corregir patrones de movimiento que causan lesiones. Readaptación y prevención de recaídas.</p>
            <a href="/tecnicas-fisioterapia/ejercicio-terapeutico/" class="technique-slide__link">Saber más →</a>
          </div>
        </div>

        <div class="technique-slide" role="listitem">
          <div class="technique-slide__img">
            <img src="/images/electroestimulacion-tens.png" alt="Electroestimulación TENS en Valladolid" loading="lazy" width="400" height="280" />
          </div>
          <div class="technique-slide__body">
            <span class="technique-slide__num font-display">03</span>
            <h3 class="technique-slide__title">Electroestimulación TENS</h3>
            <p class="technique-slide__desc">Neuroestimulación eléctrica para bloquear el dolor y mejorar la recuperación muscular. Seguro y eficaz para dolor crónico y agudo.</p>
            <a href="/tecnicas-fisioterapia/electroterapia-tens/" class="technique-slide__link">Saber más →</a>
          </div>
        </div>

        <div class="technique-slide" role="listitem">
          <div class="technique-slide__img">
            <img src="/images/presoterapia.png" alt="Presoterapia para deportistas en Valladolid" loading="lazy" width="400" height="280" />
          </div>
          <div class="technique-slide__body">
            <span class="technique-slide__num font-display">04</span>
            <h3 class="technique-slide__title">Presoterapia</h3>
            <p class="technique-slide__desc">Compresión neumática para eliminar toxinas, reducir inflamación y acelerar la recuperación. Muy valorada por deportistas.</p>
            <a href="/tecnicas-fisioterapia/presoterapia/" class="technique-slide__link">Saber más →</a>
          </div>
        </div>

        <div class="technique-slide" role="listitem">
          <div class="technique-slide__img">
            <img src="/images/kinesioterapia.png" alt="Punción seca en Valladolid" loading="lazy" width="400" height="280" />
          </div>
          <div class="technique-slide__body">
            <span class="technique-slide__num font-display">05</span>
            <h3 class="technique-slide__title">Punción Seca</h3>
            <p class="technique-slide__desc">Agujas de acupuntura para desactivar puntos gatillo que provocan dolor y limitación funcional. Resultados rápidos y duraderos.</p>
            <a href="/tecnicas-fisioterapia/puncion-seca-valladolid/" class="technique-slide__link">Saber más →</a>
          </div>
        </div>
      </div>

      <div class="techniques-nav" aria-label="Navegación del carrusel">
        <button class="techniques-prev-btn" id="tech-prev" aria-label="Técnica anterior">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="19,3 5,12 19,21"/></svg>
        </button>
        <div class="techniques-dots-pill" id="tech-dots" role="tablist" aria-label="Seleccionar técnica">
          <button class="techniques-dot active" role="tab" aria-selected="true" aria-label="Técnica 1"></button>
          <button class="techniques-dot" role="tab" aria-selected="false" aria-label="Técnica 2"></button>
          <button class="techniques-dot" role="tab" aria-selected="false" aria-label="Técnica 3"></button>
          <button class="techniques-dot" role="tab" aria-selected="false" aria-label="Técnica 4"></button>
          <button class="techniques-dot" role="tab" aria-selected="false" aria-label="Técnica 5"></button>
        </div>
        <button class="techniques-next-btn" id="tech-next" aria-label="Siguiente técnica">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ====================================================
       4. FISIOTERAPEUTA — Layout 60/40
  ===================================================== -->
  <section class="about section gs-reveal" id="fisioterapeuta" aria-label="Conoce al fisioterapeuta">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <p class="section-eyebrow font-display">Tu Fisioterapeuta</p>
          <h2 class="about-name">{config.business.owner}</h2>
          <p class="about-role">Fisioterapeuta Colegiado · Director Clínico</p>

          <p class="about-bio">
            Más de 7 años de experiencia tratando deportistas y pacientes con dolor crónico en Valladolid.
            Mi pasión por el deporte —soy runner y ciclista— me permite entender las necesidades específicas
            de cada atleta y persona, diseñando tratamientos que realmente funcionan.
          </p>
          <p class="about-bio">
            Cada sesión es un trabajo conjunto: escucho, evalúo y aplico las técnicas más avanzadas
            con evidencia científica. El objetivo no es solo aliviar el dolor, sino que entiendas
            tu cuerpo y no vuelvas a tener el mismo problema.
          </p>

          <div class="about-badges">
            <span class="about-badge">✓ Fisioterapeuta Colegiado</span>
            <span class="about-badge">✓ 7+ años de experiencia</span>
            <span class="about-badge">✓ +200 pacientes tratados</span>
            <span class="about-badge">✓ Especialista Deportivo</span>
          </div>

          <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Pide cita con Alberto
          </a>
        </div>

        <div class="about-image">
          <div class="about-image-frame" aria-label="Foto de Alberto Muñoz González, fisioterapeuta">
            <div class="about-image-placeholder">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
              <span>Foto de Alberto</span>
            </div>
          </div>
          <div class="about-image-accent" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================
       5. STATS — Fondo morado, counters GSAP
  ===================================================== -->
  <section class="stats" id="stats" aria-label="Estadísticas de la clínica">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-value" data-target={config.stats.yearsExperience} data-suffix="+">0+</span>
          <span class="stat-label">Años de experiencia</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" data-target={config.stats.patientsRecovered} data-prefix="+">0</span>
          <span class="stat-label">Pacientes recuperados</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" data-target={config.stats.manualTherapyHours} data-prefix="+" data-suffix="h">0h</span>
          <span class="stat-label">Horas de terapia manual</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" data-target={config.stats.googleRating} data-decimal="true">0</span>
          <span class="stat-label"><Star size={16} class="stat-star" aria-hidden="true" /> Valoración en Google</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================
       6. PRECIOS — 2 cards lado a lado
  ===================================================== -->
  <section class="pricing section gs-reveal" id="reservar" aria-label="Tarifas y precios">
    <div class="container">
      <div class="section-header">
        <p class="section-eyebrow font-display">Tarifas</p>
        <h2 class="section-title">Invierte en tu salud</h2>
        <p class="section-subtitle">Sesiones individuales de {config.pricing.clinica.duration}. Sin lista de espera.</p>
      </div>

      <div class="pricing-grid">

        <!-- Domicilio — izquierda -->
        <div class="pricing-card">
          <div class="pricing-card__header">
            <div class="pricing-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <h3 class="pricing-name">Sesión a domicilio</h3>
          </div>
          <p class="pricing-desc">Fisioterapia profesional en tu hogar con desplazamiento incluido.</p>
          <div class="pricing-price-row">
            <span class="pricing-amount">{config.pricing.domicilio.price}</span><span class="pricing-currency">€</span>
            <span class="pricing-period">/sesión de {config.pricing.domicilio.duration}</span>
          </div>
          <a href={waDomLink} target="_blank" rel="noopener noreferrer" class="pricing-cta pricing-cta--outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Solicitar cita a domicilio
          </a>
          <p class="pricing-includes-label">Qué incluye</p>
          <ul class="pricing-features">
            <li>Atención en la comodidad de tu hogar</li>
            <li>Todo el material incluido</li>
            <li>Valladolid capital y provincia</li>
            <li>Ideal para post-operatorio</li>
            <li>Cancelación gratuita 24h antes</li>
          </ul>
        </div>

        <!-- Clínica — centro destacada -->
        <div class="pricing-card pricing-card--featured">
          <div class="pricing-card__header">
            <div class="pricing-icon pricing-icon--green">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <h3 class="pricing-name">Reservar cita</h3>
            <span class="pricing-badge">Popular</span>
          </div>
          <p class="pricing-desc">Agenda tu primera consulta con nuestros especialistas.</p>
          <div class="pricing-price-row">
            <span class="pricing-amount">{config.pricing.clinica.price}</span><span class="pricing-currency">€</span>
            <span class="pricing-period">/sesión de {config.pricing.clinica.duration}</span>
          </div>
          <a href={waClinLink} target="_blank" rel="noopener noreferrer" class="pricing-cta pricing-cta--primary">
            Reservar mi cita ahora →
          </a>
          <p class="pricing-includes-label">Qué incluye</p>
          <ul class="pricing-features">
            <li>Primera consulta con valoración completa</li>
            <li>Sesión individual y privada</li>
            <li>Plan de tratamiento personalizado</li>
            <li>Cancelación gratuita 24h antes</li>
            <li>Pago en clínica</li>
          </ul>
        </div>

        <!-- Bonos — derecha con calculadora expandible -->
        <div class="pricing-card pricing-card--bonos" data-tiers={JSON.stringify(config.pricing.bonos.tiers)} data-wa={config.contact.whatsapp}>
