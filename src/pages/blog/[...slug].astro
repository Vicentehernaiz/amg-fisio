---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { generateBreadcrumbSchema } from '@utils/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

const seoTitle = post.data.seo?.title || `${post.data.title} | AMG Fisioterapia Blog`;
const seoDesc = post.data.seo?.description || post.data.description;

const breadcrumbs = generateBreadcrumbSchema([
  { name: 'Inicio', url: '/' },
  { name: 'Blog', url: '/blog/' },
  { name: post.data.title, url: `/blog/${post.id}/` },
]);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate || post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'AMG Fisioterapia',
  },
  image: post.data.image,
};
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  image={post.data.image}
  schema={[breadcrumbs, articleSchema]}
>
  <Header slot="header" />

  <article class="article" style="padding-top: calc(72px + var(--space-3xl));">
    <div class="container container--narrow">
      <div class="article__header">
        <a href="/blog/" class="article__back">&larr; Volver al blog</a>
        <time class="article__date" datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="article__title">{post.data.title}</h1>
        <p class="article__author">Por {post.data.author}</p>
        {post.data.tags.length > 0 && (
          <div class="article__tags">
            {post.data.tags.map((tag) => (
              <span class="article__tag">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <div class="article__content prose">
        <Content />
      </div>

      <div class="article__cta">
        <p>Necesitas ayuda con tu problema? <strong>Reserva tu cita</strong> y te ayudamos.</p>
        <a href="/#reservar" class="btn btn--primary">Reservar cita</a>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .article__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .article__back {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
    transition: color var(--duration-fast);
  }

  .article__back:hover {
    color: var(--color-primary);
  }

  .article__date {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-md);
  }

  .article__title {
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-md);
  }

  .article__author {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-md);
  }

  .article__tags {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .article__tag {
    padding: 4px 12px;
    font-size: var(--text-xs);
    background-color: var(--color-primary-50);
    color: var(--color-primary);
    border-radius: var(--radius-full);
  }

  /* Prose styles for Markdown content */
  .article__content :global(h2) {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
  }

  .article__content :global(h3) {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .article__content :global(p) {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
  }

  .article__content :global(ul),
  .article__content :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .article__content :global(li) {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }

  .article__content :global(ul li) {
    list-style-type: disc;
  }

  .article__content :global(ol li) {
    list-style-type: decimal;
  }

  .article__content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .article__content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article__cta {
    margin-top: var(--space-4xl);
    padding: var(--space-2xl);
    text-align: center;
    background-color: var(--color-primary-50);
    border-radius: var(--radius-2xl);
  }

  .article__cta p {
    margin-bottom: var(--space-lg);
    color: var(--text-secondary);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 32px;
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    transition: opacity 0.15s, transform 0.15s;
    text-decoration: none;
  }

  .btn--primary {
    background: linear-gradient(27deg, #8BAD44 17%, #95B44E 37%, #B1C96B 72%, #C4D87F 92%);
    color: #181428;
    box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.05), 0px 5px 29.2px 0px rgba(218,211,198,0.32);
  }

  .btn--primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
