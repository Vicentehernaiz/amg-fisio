---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getConfig, getWhatsAppLink } from '@utils/config';
import { generateServiceSchema, generateFAQSchema, generateBreadcrumbSchema } from '@utils/seo';

const config = getConfig();

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Técnicas', url: '/tecnicas-fisioterapia/' },
  { name: 'Electroestimulación TENS', url: '/tecnicas-fisioterapia/tens-electroestimulacion-valladolid/' },
];

const faqs = [
  {
    question: '¿El TENS duele?',
    answer: 'No. La electroestimulación TENS produce una sensación de hormigueo o vibración leve, completamente indolora, que la mayoría de pacientes describe como agradable. La intensidad siempre se ajusta a la tolerancia del paciente, y nunca debe causar dolor ni contracción muscular involuntaria (eso sería NMES, no TENS).',
  },
  {
    question: '¿Para qué sirve el TENS en fisioterapia?',
    answer: 'El TENS (Transcutaneous Electrical Nerve Stimulation) se usa principalmente para el control del dolor agudo y crónico: cervicalgia, lumbalgia, artrosis, dolor postoperatorio, dolor neuropático. También tiene efectos antiinflamatorios locales. Es especialmente útil para reducir el dolor antes o después de las maniobras de terapia manual.',
  },
  {
    question: '¿Quién no puede usar el TENS?',
    answer: 'El TENS está contraindicado en personas con marcapasos cardíaco, en el área del cuello en pacientes con problemas cardíacos, durante el embarazo (sobre el abdomen), sobre heridas abiertas o piel irritada, sobre tumores malignos y en personas con epilepsia sin control médico. Alberto evaluará tu caso antes de aplicarlo.',
  },
  {
    question: '¿Puedo comprar un TENS para casa?',
    answer: 'Existen dispositivos TENS de venta libre, pero su uso sin orientación profesional tiene limitaciones: es difícil saber la colocación correcta de los electrodos, los parámetros óptimos y si está indicado para tu caso concreto. En fisioterapia profesional, el TENS es una herramienta más dentro de un tratamiento integral, no un fin en sí mismo.',
  },
];

const serviceSchema = generateServiceSchema({
  name: 'Electroestimulación TENS en Valladolid',
  description: 'Electroestimulación TENS para el control del dolor en Valladolid. Indolora, segura y eficaz. AMG Fisioterapia.',
  url: '/tecnicas-fisioterapia/tens-electroestimulacion-valladolid/',
});

const faqSchema = generateFAQSchema(faqs);
const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);
const whatsappLink = getWhatsAppLink('Hola, me gustaría información sobre electroestimulación TENS en AMG Fisioterapia Valladolid.');
---

<BaseLayout
  title="Electroestimulación TENS Valladolid | AMG Fisioterapia"
  description="Electroestimulación TENS en Valladolid para el control del dolor: cervicalgia, lumbalgia, artrosis. Técnica segura e indolora. AMG Fisioterapia. Pide cita."
  schema={[serviceSchema, faqSchema, breadcrumbSchema]}
>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <div class="page-hero__inner">
        <div class="page-hero__text">
          <nav class="breadcrumb" aria-label="Ruta de navegación">
            <ol>
              <li><a href="/">Inicio</a></li>
              <li aria-hidden="true">›</li>
              <li><a href="/tecnicas-fisioterapia/">Técnicas</a></li>
              <li aria-hidden="true">›</li>
              <li aria-current="page">Electroestimulación TENS</li>
            </ol>
          </nav>
          <h1 class="page-hero__title font-display">Electroestimulación TENS en Valladolid</h1>
          <p class="page-hero__subtitle">Control del dolor sin fármacos. La electroestimulación TENS es una técnica segura, indolora y con evidencia científica para el manejo del dolor agudo y crónico.</p>
        </div>
        <div class="page-hero__image">
          <img src="/images/electroestimulacion-tens.png" alt="Electroestimulación TENS fisioterapia" width="800" height="500" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container content-narrow">
      <h2 class="section__title">Qué es el TENS y Cómo Funciona</h2>
      <div class="prose">
        <p>El TENS (Transcutaneous Electrical Nerve Stimulation, o Estimulación Nerviosa Eléctrica Transcutánea) es una forma de electroterapia que utiliza corrientes eléctricas de baja frecuencia, aplicadas a través de electrodos colocados sobre la piel, para estimular las fibras nerviosas y modular la percepción del dolor.</p>

        <p>El mecanismo de acción del TENS tiene una base neurofisiológica bien documentada. Según la "Teoría de la Puerta de Control del Dolor" (Melzack y Wall, 1965), la estimulación de las fibras nerviosas A-beta (que responden al tacto y la vibración) puede inhibir la transmisión de las señales de dolor a través de las fibras C (fibras del dolor). En la práctica, esto significa que el hormigueo agradable del TENS "cierra la puerta" al dolor en la médula espinal.</p>

        <p>Además, el TENS a baja frecuencia estimula la liberación de endorfinas, los analgésicos naturales del propio organismo, lo que produce una analgesia más prolongada que dura incluso horas después de retirar los electrodos.</p>

        <h3>Indicaciones del TENS en Fisioterapia</h3>
        <p>En AMG Fisioterapia, en Valladolid, utilizamos el TENS como parte del tratamiento en diversas condiciones:</p>
        <p><strong>Dolor agudo:</strong> cervicalgia, lumbalgia aguda, esguinces, dolor postoperatorio. El TENS permite trabajar mejor con técnicas manuales al reducir el umbral de dolor del paciente.</p>
        <p><strong>Dolor crónico:</strong> artrosis, fibromialgia, dolor neuropático, síndrome de dolor miofascial. En estos casos, el TENS no cura la causa del dolor, pero mejora significativamente la calidad de vida al reducir la intensidad y frecuencia del dolor.</p>
        <p><strong>Dolor postoperatorio:</strong> especialmente útil tras cirugías de rodilla, cadera o columna, donde puede reducir la necesidad de analgésicos.</p>

        <h3>Seguridad y Contraindicaciones</h3>
        <p>El TENS es una técnica muy segura cuando se aplica correctamente. Las contraindicaciones absolutas son pocas: marcapasos cardíaco, embarazo (sobre el abdomen), tumores malignos en la zona de aplicación y epilepsia no controlada. En el resto de casos, es una opción analgésica sin los efectos secundarios de los fármacos.</p>

        <p>En AMG Fisioterapia siempre evaluamos cada caso antes de aplicar el TENS y explicamos al paciente qué va a sentir. La técnica es completamente indolora y la mayoría de pacientes la describe como muy agradable.</p>
      </div>
    </div>
  </section>

  <section class="section bg-cream">
    <div class="container content-narrow">
      <h2 class="section__title text-center">Preguntas sobre el TENS</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item" name="faq-tens">
            <summary class="faq-item__question">{faq.question}</summary>
            <div class="faq-item__answer"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container text-center">
      <h2 class="cta-section__title font-display">¿Tienes dolor que quieres controlar?</h2>
      <p class="cta-section__subtitle">En AMG Fisioterapia Valladolid combinamos el TENS con otras técnicas para un resultado óptimo.</p>
      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir cita por WhatsApp
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero { background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-secondary-dark) 100%); color: var(--color-white); padding: calc(72px + var(--space-4xl)) 0 var(--space-4xl); }
  .page-hero__title { font-size: var(--text-5xl); color: var(--color-white); margin-bottom: var(--space-lg); max-width: 700px; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,0.8); max-width: 580px; line-height: var(--leading-relaxed); }
  .breadcrumb ol { display: flex; align-items: center; gap: var(--space-sm); list-style: none; font-size: var(--text-sm); color: rgba(255,255,255,0.6); margin-bottom: var(--space-xl); flex-wrap: wrap; }
  .breadcrumb a { color: rgba(255,255,255,0.7); }
  .bg-white { background: var(--color-white); }
  .bg-cream { background: var(--color-cream); }
  .section { padding-block: var(--space-4xl); }
  .text-center { text-align: center; }
  .content-narrow { max-width: 800px; margin-inline: auto; }
  .section__title { font-size: var(--text-3xl); font-weight: 700; color: var(--color-gray-900); margin-bottom: var(--space-xl); }
  .prose p { font-size: var(--text-base); line-height: var(--leading-relaxed); color: var(--text-secondary); margin-bottom: var(--space-lg); }
  .prose h3 { font-size: var(--text-xl); font-weight: 700; color: var(--color-gray-900); margin-top: var(--space-2xl); margin-bottom: var(--space-md); }
  .prose strong { color: var(--color-gray-800); }
  .faq-list { display: flex; flex-direction: column; gap: var(--space-md); }
  .faq-item { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-lg); overflow: hidden; }
  .faq-item__question { padding: var(--space-lg) var(--space-xl); font-size: var(--text-base); font-weight: 600; color: var(--color-gray-900); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: var(--space-md); }
  .faq-item__question::-webkit-details-marker { display: none; }
  .faq-item__question::after { content: '+'; font-size: var(--text-xl); color: var(--color-primary); flex-shrink: 0; transition: transform var(--duration-fast); }
  .faq-item[open] .faq-item__question::after { transform: rotate(45deg); }
  .faq-item__answer { padding: 0 var(--space-xl) var(--space-lg); }
  .faq-item__answer p { font-size: var(--text-sm); color: var(--text-secondary); line-height: var(--leading-relaxed); }
  .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); }
  .cta-section__title { font-size: var(--text-4xl); color: var(--color-white); margin-bottom: var(--space-md); }
  .cta-section__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,0.85); margin-bottom: var(--space-2xl); }
  .btn-whatsapp { display: inline-flex; align-items: center; gap: var(--space-sm); padding: var(--space-md) var(--space-2xl); background: var(--color-white); color: var(--color-primary-dark); font-weight: 700; font-size: var(--text-base); border-radius: var(--radius-full); transition: all var(--duration-fast); }
  .btn-whatsapp:hover { background: var(--color-gray-100); transform: translateY(-2px); }
  @media (max-width: 640px) { .page-hero__title { font-size: var(--text-3xl); } }
  .page-hero__inner { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; align-items: center; }
  .page-hero__image { border-radius: 20px; overflow: hidden; flex-shrink: 0; }
  .page-hero__image img { width: 100%; height: 360px; object-fit: cover; display: block; }
  @media (max-width: 900px) { .page-hero__inner { grid-template-columns: 1fr; } .page-hero__image { display: none; } }
</style>
