---
import { getConfig, getWhatsAppLink, getPhoneLink } from '@utils/config';
const config = getConfig();
const waNavLink = getWhatsAppLink('Hola, quiero pedir cita en AMG Fisioterapia.');
---

<header class="header" id="header" role="banner">

  <!-- ── NAV BAR ─────────────────────────────── -->
  <div class="header__bar">
    <div class="header__inner">

      <!-- Logo -->
      <a href="/" class="nav-logo" aria-label="AMG Fisioterapia - Inicio">
        <img src="/images/logo-main.svg" alt="AMG Fisioterapia" width="120" height="28" class="nav-logo__img" />
      </a>

      <!-- Desktop links -->
      <ul class="nav-links" role="menubar" aria-label="Navegación principal">


        <li class="has-mega" data-panel="servicios" role="none">
          <button class="nav-link nav-link--btn" role="menuitem" aria-haspopup="true" aria-expanded="false" aria-controls="panel-servicios">
            Servicios
            <svg class="nav-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </li>

        <li class="has-mega" data-panel="tecnicas" role="none">
          <button class="nav-link nav-link--btn" role="menuitem" aria-haspopup="true" aria-expanded="false" aria-controls="panel-tecnicas">
            Técnicas
            <svg class="nav-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </li>

        <li class="has-mega" data-panel="deportiva" role="none">
          <button class="nav-link nav-link--btn" role="menuitem" aria-haspopup="true" aria-expanded="false" aria-controls="panel-deportiva">
            Fisio Deportiva
            <svg class="nav-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </li>

        <li role="none">
          <a href="/fisioterapia-domicilio-valladolid/" class="nav-link" role="menuitem">A Domicilio</a>
        </li>

        <li role="none">
          <a href="/blog/" class="nav-link" role="menuitem">Blog</a>
        </li>

      </ul>

      <!-- Right -->
      <div class="nav-right">
        <a href={waNavLink} target="_blank" rel="noopener noreferrer" class="nav-cta nav-cta--contact">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contactar
        </a>
        <a href="/#reservar" class="nav-cta nav-cta--reservar">
          Reservar Cita
        </a>
      </div>

      <!-- Mobile toggle -->
      <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
      </button>

    </div>
  </div>

  <!-- ── MEGA PANELS ─────────────────────────── -->
  <div class="header__panels" id="header-panels">

    <!-- Servicios -->
    <div class="mega-panel" id="panel-servicios" role="region" aria-label="Servicios" aria-hidden="true">
      <div class="mega-inner">
        <div class="mega-col">
          <p class="mega-heading">Columna vertebral</p>
          <ul class="mega-list">
            <li><a href="/servicios-fisioterapia/cervicalgia-dolor-cervical-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Dolor Cervical
            </a></li>
            <li><a href="/servicios-fisioterapia/dolor-lumbar-lumbalgia-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Dolor Lumbar
            </a></li>
          </ul>
        </div>
        <div class="mega-col">
          <p class="mega-heading">Articulaciones</p>
          <ul class="mega-list">
            <li><a href="/servicios-fisioterapia/rehabilitacion-rodilla-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Rodilla
            </a></li>
            <li><a href="/servicios-fisioterapia/rehabilitacion-cadera-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Cadera
            </a></li>
          </ul>
        </div>
        <div class="mega-col">
          <p class="mega-heading">Especialidades</p>
          <ul class="mega-list">
            <li><a href="/servicios-fisioterapia/rehabilitacion-neurologica-ictus-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Rehabilitación Neurológica
            </a></li>
            <li><a href="/fisioterapia-domicilio-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Fisioterapia a Domicilio
            </a></li>
          </ul>
        </div>
        <div class="mega-col mega-col--cta">
          <p class="mega-cta-label">¿No sabes qué te pasa?</p>
          <p class="mega-cta-text">Cuéntanos tu caso y te orientamos sin compromiso.</p>
          <a href={waNavLink} target="_blank" rel="noopener noreferrer" class="mega-cta-btn">Consultar →</a>
        </div>
      </div>
    </div>

    <!-- Técnicas -->
    <div class="mega-panel" id="panel-tecnicas" role="region" aria-label="Técnicas" aria-hidden="true">
      <div class="mega-inner">
        <div class="mega-col">
          <p class="mega-heading">Terapia manual</p>
          <ul class="mega-list">
            <li><a href="/tecnicas-fisioterapia/terapia-manual-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Terapia Manual
            </a></li>
            <li><a href="/tecnicas-fisioterapia/ejercicio-terapeutico-readaptacion/" class="mega-link">
              <span class="mega-link__dot"></span>Ejercicio Terapéutico
            </a></li>
          </ul>
        </div>
        <div class="mega-col">
          <p class="mega-heading">Tecnología</p>
          <ul class="mega-list">
            <li><a href="/tecnicas-fisioterapia/tens-electroestimulacion-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Electroestimulación TENS
            </a></li>
            <li><a href="/tecnicas-fisioterapia/presoterapia-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Presoterapia
            </a></li>
            <li><a href="/tecnicas-fisioterapia/puncion-seca-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Punción Seca
            </a></li>
          </ul>
        </div>
        <div class="mega-col mega-col--cta">
          <p class="mega-cta-label">Tratamiento combinado</p>
          <p class="mega-cta-text">Combinamos técnicas para resultados más rápidos y duraderos.</p>
          <a href="/tecnicas-fisioterapia/" class="mega-cta-btn">Ver todas →</a>
        </div>
      </div>
    </div>

    <!-- Deportiva -->
    <div class="mega-panel" id="panel-deportiva" role="region" aria-label="Fisioterapia deportiva" aria-hidden="true">
      <div class="mega-inner">
        <div class="mega-col">
          <p class="mega-heading">Por deporte</p>
          <ul class="mega-list">
            <li><a href="/fisioterapia-deportiva-valladolid/fisioterapia-running-corredores/" class="mega-link">
              <span class="mega-link__dot"></span>Running y Corredores
            </a></li>
            <li><a href="/fisioterapia-deportiva-valladolid/fisioterapia-ciclismo-ciclistas/" class="mega-link">
              <span class="mega-link__dot"></span>Ciclismo
            </a></li>
            <li><a href="/fisioterapia-deportiva-valladolid/readaptacion-deportiva-return-to-play/" class="mega-link">
              <span class="mega-link__dot"></span>Readaptación Deportiva
            </a></li>
          </ul>
        </div>
        <div class="mega-col">
          <p class="mega-heading">Lesiones frecuentes</p>
          <ul class="mega-list">
            <li><a href="/fisioterapia-deportiva-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Esguinces y distensiones
            </a></li>
            <li><a href="/fisioterapia-deportiva-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Tendinopatías
            </a></li>
            <li><a href="/fisioterapia-deportiva-valladolid/" class="mega-link">
              <span class="mega-link__dot"></span>Return to Play
            </a></li>
          </ul>
        </div>
        <div class="mega-col mega-col--cta">
          <p class="mega-cta-label">Fisioterapeuta deportista</p>
          <p class="mega-cta-text">Alberto es runner y ciclista. Entiende lo que necesitas.</p>
          <a href="/sobre-nosotros/" class="mega-cta-btn">Conocer a Alberto →</a>
        </div>
      </div>
    </div>

  </div><!-- /header__panels -->

</header>

<!-- ── MOBILE MENU (fuera del pill) ──────────── -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menú de navegación">
  <ul class="mobile-menu__list">
    <li>
      <a href="/servicios-fisioterapia/" class="mobile-menu__link">Servicios</a>
      <ul class="mobile-menu__sub">
        <li><a href="/servicios-fisioterapia/cervicalgia-dolor-cervical-valladolid/">Dolor Cervical</a></li>
        <li><a href="/servicios-fisioterapia/dolor-lumbar-lumbalgia-valladolid/">Dolor Lumbar</a></li>
        <li><a href="/servicios-fisioterapia/rehabilitacion-rodilla-valladolid/">Rodilla</a></li>
        <li><a href="/servicios-fisioterapia/rehabilitacion-cadera-valladolid/">Cadera</a></li>
        <li><a href="/servicios-fisioterapia/rehabilitacion-neurologica-ictus-valladolid/">Neurológica</a></li>
      </ul>
    </li>
    <li>
      <a href="/tecnicas-fisioterapia/" class="mobile-menu__link">Técnicas</a>
      <ul class="mobile-menu__sub">
        <li><a href="/tecnicas-fisioterapia/terapia-manual-valladolid/">Terapia Manual</a></li>
        <li><a href="/tecnicas-fisioterapia/ejercicio-terapeutico-readaptacion/">Ejercicio Terapéutico</a></li>
        <li><a href="/tecnicas-fisioterapia/tens-electroestimulacion-valladolid/">TENS</a></li>
        <li><a href="/tecnicas-fisioterapia/presoterapia-valladolid/">Presoterapia</a></li>
        <li><a href="/tecnicas-fisioterapia/puncion-seca-valladolid/">Punción Seca</a></li>
      </ul>
    </li>
    <li>
      <a href="/fisioterapia-deportiva-valladolid/" class="mobile-menu__link">Fisio Deportiva</a>
      <ul class="mobile-menu__sub">
        <li><a href="/fisioterapia-deportiva-valladolid/fisioterapia-running-corredores/">Running</a></li>
        <li><a href="/fisioterapia-deportiva-valladolid/fisioterapia-ciclismo-ciclistas/">Ciclismo</a></li>
        <li><a href="/fisioterapia-deportiva-valladolid/readaptacion-deportiva-return-to-play/">Readaptación</a></li>
      </ul>
    </li>
    <li><a href="/fisioterapia-domicilio-valladolid/" class="mobile-menu__link">A Domicilio</a></li>
    <li><a href="/blog/" class="mobile-menu__link">Blog</a></li>
  </ul>
  <div class="mobile-menu__actions">
    <a href={waNavLink} target="_blank" rel="noopener noreferrer" class="mobile-menu__btn mobile-menu__btn--wa">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp
    </a>
    <a href={getPhoneLink()} class="mobile-menu__btn mobile-menu__btn--call">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.11 11 19.79 19.79 0 0 1 1.04 2.48 2 2 0 0 1 3 .5h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.09a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 15z"/></svg>
      {config.contact.phoneDisplay}
    </a>
  </div>
</div>

<style>
/* =====================================================
   FLOATING PILL HEADER
===================================================== */
.header {
  position: fixed;
  top: 12px;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 24px);
  max-width: 1320px;
  z-index: var(--z-sticky);
  background: #181428;
  border-radius: 34px;
  /* Grid trick: nav bar row + collapsible panels row */
  display: grid;
  grid-template-rows: 68px 0fr;
  transition: grid-template-rows 0.38s cubic-bezier(0.16, 1, 0.3, 1),
              box-shadow 0.3s;
  box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.22), 0 5px 29.2px 0 rgba(0, 0, 0, 0.22);
  overflow: hidden;
}

.header.mega-open {
  grid-template-rows: 68px 1fr;
  border-radius: 34px;
  box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.35), 0 5px 29.2px 0 rgba(0, 0, 0, 0.35);
}

/* ── Bar ── */
.header__bar {
  min-height: 0;
}

.header__inner {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  height: 68px;
  padding: 0 20px 0 30px;
  gap: 8px;
}

/* Logo */
.nav-logo__img {
  height: 26px;
  width: auto;
  filter: brightness(0) invert(1);
  opacity: 0.92;
}

/* Nav links */
.nav-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 8px 14px;
  font-size: 0.85rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.78);
  border-radius: 10px;
  text-decoration: none;
  transition: color 0.15s, background 0.15s;
  white-space: nowrap;
  letter-spacing: 0.01em;
}

.nav-link--btn {
  background: none;
  border: none;
  cursor: pointer;
  font-family: inherit;
}

.nav-link:hover,
.nav-link--btn:hover,
.has-mega.is-active .nav-link--btn {
  color: rgba(255, 255, 255, 1);
  background: rgba(255, 255, 255, 0.08);
}

.nav-chevron {
  transition: transform 0.22s;
  flex-shrink: 0;
  opacity: 0.7;
}

.has-mega.is-active .nav-chevron {
  transform: rotate(180deg);
  opacity: 1;
}

/* Right side */
.nav-right {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}

.nav-cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 44px;
  padding: 0 18px;
  font-size: 0.82rem;
  font-weight: 600;
  border-radius: 999px;
  white-space: nowrap;
  transition: opacity 0.15s, transform 0.15s;
  text-decoration: none;
}

.nav-cta--contact {
  background: #746F86;
  color: white;
}

.nav-cta--contact:hover {
  opacity: 0.88;
  transform: translateY(-1px);
}

.nav-cta--reservar {
  background: linear-gradient(27deg, #8BAD44 17%, #95B44E 37%, #B1C96B 72%, #C4D87F 92%);
  color: #181428;
  box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.05), 0px 5px 29.2px 0px rgba(218,211,198,0.32);
}

.nav-cta--reservar:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

/* Mobile toggle — hidden on desktop */
.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 8px;
  background: none;
  border: none;
  cursor: pointer;
  flex-shrink: 0;
}

.nav-toggle__line {
  display: block;
  width: 22px;
  height: 2px;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 2px;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

/* =====================================================
   MEGA PANELS
===================================================== */
.header__panels {
  min-height: 0; /* crucial for grid row collapse */
  overflow: hidden;
}

.mega-panel {
  display: none;
  padding: 32px 28px 40px;
  border-top: 1px solid rgba(255, 255, 255, 0.07);
  animation: megaFadeIn 0.2s ease forwards;
}

.mega-panel.is-active {
  display: block;
}

@keyframes megaFadeIn {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.mega-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}

.mega-col {
  padding: 0 24px;
  border-right: 1px solid rgba(255, 255, 255, 0.06);
}

.mega-col:first-child { padding-left: 0; }
.mega-col:last-child  { border-right: none; }

.mega-heading {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-primary);
  margin-bottom: 16px;
}

.mega-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.mega-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 0;
  font-size: 0.9rem;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.72);
  text-decoration: none;
  border-radius: 8px;
  transition: color 0.15s;
}

.mega-link:hover {
  color: rgba(255, 255, 255, 1);
}

.mega-link:hover .mega-link__dot {
  background: var(--color-primary);
  transform: scale(1.4);
}

.mega-link__dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
  transition: background 0.15s, transform 0.15s;
}

/* CTA column */
.mega-col--cta {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.mega-cta-label {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--color-primary-300);
  margin-bottom: 8px;
  letter-spacing: 0.02em;
}

.mega-cta-text {
  font-size: 0.82rem;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.5;
  margin-bottom: 16px;
}

.mega-cta-btn {
  display: inline-flex;
  align-items: center;
  padding: 9px 18px;
  background: rgba(166, 201, 88, 0.15);
  border: 1px solid rgba(166, 201, 88, 0.3);
  color: var(--color-primary-300);
  font-size: 0.82rem;
  font-weight: 600;
  border-radius: 999px;
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s;
  width: fit-content;
}

.mega-cta-btn:hover {
  background: rgba(166, 201, 88, 0.25);
  border-color: rgba(166, 201, 88, 0.5);
  color: var(--color-primary-200);
}

/* =====================================================
   MOBILE MENU (outside the pill)
===================================================== */
.mobile-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: calc(var(--z-sticky) - 1);
  background: #181428;
  padding: 96px var(--container-padding) var(--container-padding);
  overflow-y: auto;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.mobile-menu.is-open {
  transform: translateX(0);
}

.mobile-menu__list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.mobile-menu__link {
  display: block;
  padding: 14px 0;
  font-size: 1.1rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  text-decoration: none;
}

.mobile-menu__sub {
  list-style: none;
  padding: 8px 0 8px 16px;
}

.mobile-menu__sub li a {
  display: block;
  padding: 7px 0;
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.45);
  text-decoration: none;
  transition: color 0.15s;
}

.mobile-menu__sub li a:hover { color: rgba(255, 255, 255, 0.85); }

.mobile-menu__actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 28px;
}

.mobile-menu__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 14px;
  font-size: 0.9rem;
  font-weight: 600;
  color: white;
  border-radius: 12px;
  text-decoration: none;
  text-align: center;
}

.mobile-menu__btn--wa   { background: #25D366; }
.mobile-menu__btn--call { background: rgba(255,255,255,0.1); }

/* =====================================================
   RESPONSIVE
===================================================== */
@media (max-width: 1024px) {
  .header__inner {
    grid-template-columns: auto 1fr auto;
  }

  .nav-links {
    display: none;
  }

  .nav-toggle { display: flex; }

  .nav-right .nav-cta { display: none; }
}

@media (max-width: 480px) {
  .header {
    width: calc(100% - 16px);
    top: 8px;
    border-radius: 34px;
  }
}
</style>

<script>
(function () {
  const header     = document.getElementById('header');
  const panels     = document.querySelectorAll('.mega-panel');
  const megaItems  = document.querySelectorAll('.has-mega');
  const toggle     = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  // ── Mega menu ──────────────────────────────
  function openPanel(panelId: string) {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }

    panels.forEach(p => {
      p.classList.remove('is-active');
      p.setAttribute('aria-hidden', 'true');
    });
    megaItems.forEach(i => {
      i.classList.remove('is-active');
      i.querySelector('[aria-expanded]')?.setAttribute('aria-expanded', 'false');
    });

    const target = document.getElementById(`panel-${panelId}`);
    const triggerItem = document.querySelector(`[data-panel="${panelId}"]`);

    if (target) {
      target.classList.add('is-active');
      target.setAttribute('aria-hidden', 'false');
    }
    if (triggerItem) {
      triggerItem.classList.add('is-active');
      triggerItem.querySelector('[aria-expanded]')?.setAttribute('aria-expanded', 'true');
    }
    header?.classList.add('mega-open');
  }

  function closePanels() {
    closeTimer = setTimeout(() => {
      panels.forEach(p => {
        p.classList.remove('is-active');
        p.setAttribute('aria-hidden', 'true');
      });
      megaItems.forEach(i => {
        i.classList.remove('is-active');
        i.querySelector('[aria-expanded]')?.setAttribute('aria-expanded', 'false');
      });
      header?.classList.remove('mega-open');
    }, 120);
  }

  // Hover on nav items with dropdowns
  megaItems.forEach(item => {
    item.addEventListener('mouseenter', () => {
      openPanel((item as HTMLElement).dataset.panel || '');
    });
    item.addEventListener('mouseleave', closePanels);

    // Also open on focus (keyboard)
    item.querySelector('button')?.addEventListener('focus', () => {
      openPanel((item as HTMLElement).dataset.panel || '');
    });
  });

  // Keep panel open when hovering the panel itself
  const panelsWrapper = document.getElementById('header-panels');
  panelsWrapper?.addEventListener('mouseenter', () => {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
  });
  panelsWrapper?.addEventListener('mouseleave', closePanels);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closePanels();
      mobileMenu?.classList.remove('is-open');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
  });

  // ── Mobile menu ────────────────────────────
  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';

    const lines = toggle.querySelectorAll('.nav-toggle__line');
    if (isOpen) {
      (lines[0] as HTMLElement).style.transform = 'rotate(45deg) translate(5px, 5px)';
      (lines[1] as HTMLElement).style.opacity = '0';
      (lines[2] as HTMLElement).style.transform = 'rotate(-45deg) translate(5px, -5px)';
    } else {
      lines.forEach(l => { (l as HTMLElement).removeAttribute('style'); });
    }
  });

  // ── Scroll shadow ──────────────────────────
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }, { passive: true });
})();
</script>
