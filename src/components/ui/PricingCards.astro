---
import { getConfig, getWhatsAppLink } from '@utils/config';
const config = getConfig();
const waClinLink = getWhatsAppLink('Hola, me gustaría reservar una sesión en clínica en AMG Fisioterapia.');
const waDomLink  = getWhatsAppLink('Hola, me gustaría reservar una sesión a domicilio en AMG Fisioterapia.');
const waBonLink  = getWhatsAppLink('Hola, me gustaría información sobre los bonos de sesiones en AMG Fisioterapia.');
---

<div class="pricing-cards" aria-label="Tarifas de fisioterapia">
  <div class="pc pc--featured">
    <div class="pc__badge">Más popular</div>
    <h3 class="pc__name">{config.pricing.clinica.label}</h3>
    <div class="pc__price">
      <span class="pc__amount">{config.pricing.clinica.price}</span>
      <span class="pc__currency">€</span>
      <span class="pc__period">/ sesión</span>
    </div>
    <p class="pc__duration">{config.pricing.clinica.duration} · Sesión individual</p>
    <ul class="pc__features">
      <li>Valoración completa incluida</li>
      <li>Sesión individual y privada</li>
      <li>Plan de tratamiento personalizado</li>
      <li>Seguimiento entre sesiones</li>
      <li>Cancelación gratuita 24h antes</li>
    </ul>
    <a href={waClinLink} target="_blank" rel="noopener noreferrer" class="pc__cta pc__cta--primary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Reservar en clínica
    </a>
  </div>

  <div class="pc">
    <h3 class="pc__name">{config.pricing.domicilio.label}</h3>
    <div class="pc__price">
      <span class="pc__amount">{config.pricing.domicilio.price}</span>
      <span class="pc__currency">€</span>
      <span class="pc__period">/ sesión</span>
    </div>
    <p class="pc__duration">{config.pricing.domicilio.duration} · En tu casa</p>
    <ul class="pc__features">
      <li>Material incluido</li>
      <li>Valladolid y provincia</li>
      <li>Ideal para post-operatorio</li>
      <li>Sin desplazamiento para ti</li>
      <li>Cancelación gratuita 24h antes</li>
    </ul>
    <a href={waDomLink} target="_blank" rel="noopener noreferrer" class="pc__cta pc__cta--outline">
      Reservar a domicilio
    </a>
  </div>

  <p class="pricing-cards__bonos">
    ¿Necesitas varias sesiones?
    <a href={waBonLink} target="_blank" rel="noopener noreferrer">Consulta nuestros bonos →</a>
  </p>
</div>

<style>
  .pricing-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    align-items: start;
  }

  .pricing-cards__bonos {
    grid-column: 1 / -1;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-top: var(--space-md);
  }

  .pricing-cards__bonos a {
    color: var(--color-primary);
    font-weight: 600;
  }

  .pc {
    padding: var(--space-2xl);
    background: var(--color-white);
    border: 1.5px solid var(--color-gray-200);
    border-radius: 20px;
    position: relative;
  }

  .pc--featured {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary), var(--shadow-xl);
    transform: scale(1.03);
  }

  .pc__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    padding: 5px 18px;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: 700;
    font-family: var(--font-display);
    letter-spacing: 0.05em;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .pc__name {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .pc__price {
    display: flex;
    align-items: baseline;
    gap: 2px;
    margin-bottom: var(--space-xs);
  }

  .pc__amount {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
  }

  .pc__currency {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-secondary);
  }

  .pc__period {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-left: 4px;
  }

  .pc__duration {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: var(--space-lg);
  }

  .pc__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .pc__features li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
  }

  .pc__features li::before {
    content: '✓';
    color: var(--color-primary);
    font-weight: 700;
    flex-shrink: 0;
  }

  .pc__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    width: 100%;
    padding: 12px 20px;
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    transition: all 0.2s;
    text-align: center;
  }

  .pc__cta--primary {
    background: linear-gradient(27deg, #8BAD44 17%, #95B44E 37%, #B1C96B 72%, #C4D87F 92%);
    color: #181428;
    box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.05), 0px 5px 29.2px 0px rgba(218,211,198,0.32);
  }

  .pc__cta--primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .pc__cta--outline {
    border: 1.5px solid var(--color-primary);
    color: var(--color-primary);
    background: transparent;
  }

  .pc__cta--outline:hover {
    background: var(--color-primary-50);
  }

  @media (max-width: 640px) {
    .pricing-cards {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-inline: auto;
    }
    .pc--featured { transform: none; }
  }
</style>
