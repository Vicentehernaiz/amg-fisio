---
import { getConfig, getWhatsAppLink, getPhoneLink, getEmailLink } from '@utils/config';
const config = getConfig();
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <!-- Top Section -->
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" aria-label="AMG Fisioterapia - Inicio">
          <img src="/images/logo-bw.svg" alt="AMG Fisioterapia" width="140" height="32" class="footer__logo" />
        </a>
        <p class="footer__tagline">
          Fisioterapia avanzada en Valladolid Centro. Tratamientos personalizados para tu recuperacion.
        </p>
      </div>

      <div class="footer__links">
        <div class="footer__col">
          <h3 class="footer__heading">Servicios</h3>
          <ul>
            <li><a href="/servicios-fisioterapia/cervicalgia-dolor-cervical-valladolid/">Dolor Cervical</a></li>
            <li><a href="/servicios-fisioterapia/dolor-lumbar-lumbalgia-valladolid/">Dolor Lumbar</a></li>
            <li><a href="/servicios-fisioterapia/rehabilitacion-rodilla-valladolid/">Rehabilitacion Rodilla</a></li>
            <li><a href="/servicios-fisioterapia/rehabilitacion-neurologica-ictus-valladolid/">Neurologia / Ictus</a></li>
            <li><a href="/fisioterapia-deportiva-valladolid/">Fisioterapia Deportiva</a></li>
            <li><a href="/fisioterapia-domicilio-valladolid/">A Domicilio</a></li>
          </ul>
        </div>

        <div class="footer__col">
          <h3 class="footer__heading">Tecnicas</h3>
          <ul>
            <li><a href="/tecnicas-fisioterapia/terapia-manual-valladolid/">Terapia Manual</a></li>
            <li><a href="/tecnicas-fisioterapia/ejercicio-terapeutico-readaptacion/">Ejercicio Terapeutico</a></li>
            <li><a href="/tecnicas-fisioterapia/tens-electroestimulacion-valladolid/">Electroestimulacion</a></li>
            <li><a href="/tecnicas-fisioterapia/presoterapia-valladolid/">Presoterapia</a></li>
            <li><a href="/tecnicas-fisioterapia/puncion-seca-valladolid/">Puncion Seca</a></li>
          </ul>
        </div>

        <div class="footer__col">
          <h3 class="footer__heading">Contacto</h3>
          <ul class="footer__contact">
            <li>
              <a href={getPhoneLink()}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                {config.contact.phoneDisplay}
              </a>
            </li>
            <li>
              <a href={getEmailLink()}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                {config.contact.email}
              </a>
            </li>
            <li>
              <a href={config.contact.googleMapsUrl} target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                {config.contact.address.street}, {config.contact.address.city}
              </a>
            </li>
          </ul>
          <div class="footer__hours">
            {config.hours.schedule.map((s) => (
              <p><strong>{s.days}:</strong> {s.hours}</p>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Trust Section -->
    <div class="footer__trust">
      <p class="footer__trust-quote">"Más de 7 años ayudando a recuperarse en Valladolid"</p>
      <div class="footer__trust-badges">
        <span class="footer__badge">✓ Fisioterapeuta Colegiado</span>
        <span class="footer__badge">⭐ 4.9 Google</span>
        <span class="footer__badge">+200 pacientes</span>
      </div>
      <a
        href={`https://wa.me/${config.contact.whatsapp}?text=${encodeURIComponent('Hola, me gustaría pedir cita en AMG Fisioterapia.')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__wa-btn"
      >
        Pedir cita por WhatsApp
      </a>
    </div>

    <!-- Bottom Section -->
    <div class="footer__bottom">
      <p>&copy; {currentYear} {config.business.name}. Todos los derechos reservados.</p>
      <div class="footer__legal">
        <a href="/aviso-legal/">Aviso Legal</a>
        <a href="/politica-privacidad/">Privacidad</a>
        <a href="/politica-cookies/">Cookies</a>
      </div>
      <div class="footer__social">
        <a href={config.social.instagram} target="_blank" rel="noopener" aria-label="Instagram de AMG Fisioterapia">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
        </a>
        <a href={config.social.googleBusiness} target="_blank" rel="noopener" aria-label="Google Business de AMG Fisioterapia">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #181428;
    color: var(--color-gray-300);
    padding-block: var(--space-4xl) var(--space-xl);
    border-radius: 32px;
    margin: 10px;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr 3fr;
    gap: var(--space-4xl);
    padding-bottom: var(--space-3xl);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__logo {
    filter: brightness(0) invert(1);
    margin-bottom: var(--space-md);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-gray-400);
    max-width: 280px;
  }

  .footer__links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-md);
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__col a {
    font-size: var(--text-sm);
    color: var(--color-gray-400);
    transition: color var(--duration-fast);
  }

  .footer__col a:hover {
    color: var(--color-primary);
  }

  .footer__contact a {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer__contact svg {
    flex-shrink: 0;
    color: var(--color-primary);
  }

  .footer__hours {
    margin-top: var(--space-md);
    font-size: var(--text-xs);
    color: var(--color-gray-500);
  }

  .footer__hours p {
    margin-bottom: 2px;
  }

  .footer__hours strong {
    color: var(--color-gray-400);
  }

  /* Trust section */
  .footer__trust {
    text-align: center;
    padding-block: var(--space-2xl);
    border-top: 1px solid rgba(255,255,255,0.06);
    margin-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .footer__trust-quote {
    font-size: var(--text-sm);
    color: var(--color-gray-400);
    font-style: italic;
  }

  .footer__trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }

  .footer__badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background: rgba(119,180,131,0.1);
    border: 1px solid rgba(119,180,131,0.2);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: var(--color-primary-300);
  }

  .footer__wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 22px;
    background: #25D366;
    color: white;
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    transition: background 0.2s;
  }

  .footer__wa-btn:hover { background: #1FAD54; }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-xl);
    font-size: var(--text-xs);
    color: var(--color-gray-500);
  }

  .footer__social {
    display: flex;
    gap: var(--space-md);
  }

  .footer__social a {
    color: var(--color-gray-500);
    transition: color var(--duration-fast);
  }

  .footer__social a:hover { color: var(--color-primary); }

  .footer__legal {
    display: flex;
    gap: var(--space-lg);
  }

  .footer__legal a {
    color: var(--color-gray-500);
    transition: color var(--duration-fast);
  }

  .footer__legal a:hover {
    color: var(--color-gray-300);
  }

  @media (max-width: 1024px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .footer__links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .footer__links {
      grid-template-columns: 1fr;
    }

    .footer__bottom {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }
  }
</style>
