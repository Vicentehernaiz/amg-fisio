# AMG Fisio - Variables de entorno
# Copia este archivo como .env y ajusta los valores

# URL del sitio (cambiar en produccion)
SITE_URL=http://localhost:4321

# Contraseña del panel admin /full-gas
# En produccion se configura en Vercel; aqui pon el valor solo si vas a probar en local.
ADMIN_PASSWORD=cambia-esto-en-tu-env-local

# Puerto del servidor
PORT=4321
HOST=0.0.0.0

# Google Analytics (opcional — dejar vacio para deshabilitar)
PUBLIC_GA_ID=G-XXXXXXXXXX

# GitHub fine-grained PAT con Contents: Read+Write sobre Vicentehernaiz/amg-fisio.
# Lo usa el panel /full-gas para guardar posts/config como commits al repo.
# En produccion se configura como env var en Vercel; aqui solo si quieres
# probar la integracion en local con `npm run dev`.
BLOG_GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXXXXX
